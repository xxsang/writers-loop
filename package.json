{
  "name": "writers-loop",
  "version": "0.1.0",
  "description": "A portable writing skill for planning, drafting, critique, revision, translation, style learning, and local preference learning.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Writer's Loop contributors",
  "homepage": "https://github.com/xxsang/writers-loop",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xxsang/writers-loop.git"
  },
  "keywords": [
    "ai-skills",
    "writing",
    "critique",
    "revision",
    "style-learning",
    "style-distillation",
    "translation",
    "preference-learning"
  ],
  "scripts": {
    "validate": "node tools/validate-skill.mjs skills/writers-loop",
    "scan:secrets": "node tools/scan-secrets.mjs",
    "eval": "node tools/run-evals.mjs",
    "eval:ab": "node tools/run-evals.mjs --ab-control tools/evals/control-responses.codex.json --ab-treatment tools/evals/treatment-responses.codex.json",
    "eval:ab:live": "node tools/run-live-ab-evals.mjs",
    "eval:ab:live:dry": "node tools/run-live-ab-evals.mjs --dry-run",
    "release:evidence": "node tools/run-live-ab-evals.mjs --evidence",
    "release:evidence:dry": "node tools/run-live-ab-evals.mjs --evidence --dry-run",
    "journal:init": "node skills/writers-loop/scripts/journal.mjs init",
    "journal:append": "node skills/writers-loop/scripts/journal.mjs append",
    "journal:derive": "node skills/writers-loop/scripts/journal.mjs derive",
    "style:init": "node skills/writers-loop/scripts/style-pack.mjs init",
    "style:save": "node skills/writers-loop/scripts/style-pack.mjs save",
    "style:list": "node skills/writers-loop/scripts/style-pack.mjs list",
    "style:show": "node skills/writers-loop/scripts/style-pack.mjs show",
    "test:real": "node tools/run-real-usage-tests.mjs",
    "test": "npm run validate && npm run scan:secrets && npm run eval && npm run eval:ab && npm run test:real"
  }
}
